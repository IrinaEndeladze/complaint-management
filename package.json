{
  "name": "complaint-management",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.17.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-complaints": "cds watch --open com.mycompany.complaints.complaints/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "cds": {
    "requires": {
      "[development]": {
        "auth": {
          "kind": "mocked",
          "users": {
            "agent": {
              "password": "agent",
              "roles": [
                "SupportAgent"
              ]
            },
            "manager": {
              "password": "manager",
              "roles": [
                "SupportAgent",
                "ComplaintManager"
              ]
            },
            "viewer": {
              "password": "viewer",
              "roles": []
            }
          }
        }
      },
      "[production]": {
        "auth": "xsuaa"
      },
      "html5-repo": true,
      "destinations": true,
      "workzone": true
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/complaints"
  ]
}
