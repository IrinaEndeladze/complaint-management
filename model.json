{
  "definitions": {
    "ComplaintsService": {
      "@source": "srv/services.cds",
      "kind": "service",
      "@path": "/complaint",
      "@requires": "authenticated-user"
    },
    "ComplaintsService.Complaints": {
      "kind": "entity",
      "@odata.draft.enabled": true,
      "@restrict": [
        {
          "grant": [
            "READ",
            "CREATE",
            "UPDATE"
          ],
          "to": "SupportAgent"
        },
        {
          "grant": "*",
          "to": "ComplaintManager"
        }
      ],
      "projection": {
        "from": {
          "ref": [
            "com.mycompany.complaints.Complaints"
          ]
        }
      },
      "elements": {
        "ID": {
          "key": true,
          "type": "cds.UUID"
        },
        "createdAt": {
          "@cds.on.insert": {
            "=": "$now"
          },
          "@UI.HiddenFilter": true,
          "@UI.ExcludeFromNavigationContext": true,
          "@Core.Immutable": true,
          "@title": "{i18n>CreatedAt}",
          "@readonly": true,
          "type": "cds.Timestamp"
        },
        "createdBy": {
          "@cds.on.insert": {
            "=": "$user"
          },
          "@UI.HiddenFilter": true,
          "@UI.ExcludeFromNavigationContext": true,
          "@Core.Immutable": true,
          "@title": "{i18n>CreatedBy}",
          "@readonly": true,
          "@description": "{i18n>UserID.Description}",
          "type": "User",
          "length": 255
        },
        "modifiedAt": {
          "@cds.on.insert": {
            "=": "$now"
          },
          "@cds.on.update": {
            "=": "$now"
          },
          "@UI.HiddenFilter": true,
          "@UI.ExcludeFromNavigationContext": true,
          "@title": "{i18n>ChangedAt}",
          "@readonly": true,
          "type": "cds.Timestamp"
        },
        "modifiedBy": {
          "@cds.on.insert": {
            "=": "$user"
          },
          "@cds.on.update": {
            "=": "$user"
          },
          "@UI.HiddenFilter": true,
          "@UI.ExcludeFromNavigationContext": true,
          "@title": "{i18n>ChangedBy}",
          "@readonly": true,
          "@description": "{i18n>UserID.Description}",
          "type": "User",
          "length": 255
        },
        "subject": {
          "type": "cds.String",
          "length": 150,
          "notNull": true
        },
        "description": {
          "type": "cds.LargeString",
          "notNull": true
        },
        "priority": {
          "type": "com.mycompany.complaints.ComplaintPriority",
          "length": 10,
          "default": {
            "val": "MEDIUM"
          }
        },
        "reportedAt": {
          "type": "cds.Timestamp"
        },
        "resolvedAt": {
          "type": "cds.Timestamp"
        },
        "resolutionSummary": {
          "type": "cds.LargeString"
        },
        "customer": {
          "type": "cds.Association",
          "target": "ComplaintsService.Customers",
          "keys": [
            {
              "ref": [
                "ID"
              ]
            }
          ],
          "notNull": true
        },
        "product": {
          "type": "cds.Association",
          "target": "ComplaintsService.Products",
          "keys": [
            {
              "ref": [
                "ID"
              ]
            }
          ]
        },
        "status": {
          "type": "cds.Association",
          "target": "ComplaintsService.Statuses",
          "keys": [
            {
              "ref": [
                "ID"
              ]
            }
          ],
          "notNull": true
        },
        "comments": {
          "type": "cds.Composition",
          "cardinality": {
            "max": "*"
          },
          "target": "ComplaintsService.ComplaintComments",
          "on": [
            {
              "ref": [
                "comments",
                "complaint"
              ]
            },
            "=",
            {
              "ref": [
                "$self"
              ]
            }
          ]
        }
      }
    },
